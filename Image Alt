javascript:(function(){
  // Create modal overlay
  const overlay = document.createElement('div');
  overlay.style.cssText = `
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.8);
    z-index: 999999;
    overflow: auto;
    padding: 20px;
    box-sizing: border-box;
  `;
  
  // Create container
  const container = document.createElement('div');
  container.style.cssText = `
    background: white;
    border-radius: 8px;
    max-width: 95%;
    margin: 0 auto;
    position: relative;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  `;
  
  // Create header
  const header = document.createElement('div');
  header.style.cssText = `
    padding: 15px 20px;
    border-bottom: 1px solid #ddd;
    background: #f5f5f5;
    border-radius: 8px 8px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  `;
  
  const title = document.createElement('h2');
  title.textContent = 'Image Analysis Report';
  title.style.cssText = 'margin: 0; color: #333; font-size: 18px;';
  
  const closeBtn = document.createElement('button');
  closeBtn.textContent = '×';
  closeBtn.style.cssText = `
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #666;
    padding: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  `;
  closeBtn.onclick = () => document.body.removeChild(overlay);
  
  header.appendChild(title);
  header.appendChild(closeBtn);
  
  // Function to get XPath
  function getXPath(element) {
    if (element.id) {
      return `//*[@id="${element.id}"]`;
    }
    
    let path = [];
    while (element && element.nodeType === Node.ELEMENT_NODE) {
      let index = 0;
      let hasFollowingSiblings = false;
      let hasPrecedingSiblings = false;
      
      for (let sibling = element.previousSibling; sibling; sibling = sibling.previousSibling) {
        if (sibling.nodeType === Node.ELEMENT_NODE && sibling.nodeName === element.nodeName) {
          hasPrecedingSiblings = true;
          index++;
        }
      }
      
      for (let sibling = element.nextSibling; sibling; sibling = sibling.nextSibling) {
        if (sibling.nodeType === Node.ELEMENT_NODE && sibling.nodeName === element.nodeName) {
          hasFollowingSiblings = true;
          break;
        }
      }
      
      let tagName = element.nodeName.toLowerCase();
      let pathIndex = (hasPrecedingSiblings || hasFollowingSiblings) ? `[${index + 1}]` : '';
      path.unshift(tagName + pathIndex);
      
      element = element.parentNode;
    }
    
    return path.length ? '/' + path.join('/') : '';
  }
  
  // Function to get HTML snippet
  function getHTMLSnippet(element) {
    const clone = element.cloneNode(true);
    // Truncate long src URLs for display
    if (clone.src && clone.src.length > 50) {
      clone.src = clone.src.substring(0, 47) + '...';
    }
    return clone.outerHTML;
  }
  
  // Function to get figcaption
  function getFigcaption(img) {
    const figure = img.closest('figure');
    if (figure) {
      const figcaption = figure.querySelector('figcaption');
      return figcaption ? figcaption.textContent.trim() : '';
    }
    return '';
  }
  
  // Function to resolve labelledby
  function resolveAriaLabelledby(element) {
    const labelledby = element.getAttribute('aria-labelledby');
    if (!labelledby) return '';
    
    const ids = labelledby.split(/\s+/);
    const labels = ids.map(id => {
      const el = document.getElementById(id);
      return el ? el.textContent.trim() : `[#${id} not found]`;
    });
    return labels.join(' ');
  }
  
  // Get all images
  const images = document.querySelectorAll('img');
  
  // Create table
  const tableContainer = document.createElement('div');
  tableContainer.style.cssText = `
    padding: 20px;
    max-height: 70vh;
    overflow: auto;
  `;
  
  if (images.length === 0) {
    tableContainer.innerHTML = '<p style="text-align: center; color: #666; font-size: 16px;">No images found on this page.</p>';
  } else {
    const table = document.createElement('table');
    table.style.cssText = `
      width: 100%;
      border-collapse: collapse;
      font-family: Arial, sans-serif;
      font-size: 14px;
    `;
    
    // Create header row
    const headerRow = document.createElement('tr');
    const headers = ['Image', 'Alt Attribute', 'aria-label', 'aria-labelledby', 'figcaption', 'Role', 'Location'];
    headers.forEach(headerText => {
      const th = document.createElement('th');
      th.textContent = headerText;
      th.style.cssText = `
        border: 1px solid #ddd;
        padding: 8px;
        background: #f8f9fa;
        text-align: left;
        font-weight: bold;
        white-space: nowrap;
      `;
      headerRow.appendChild(th);
    });
    table.appendChild(headerRow);
    
    // Create data rows
    images.forEach((img, index) => {
      const row = document.createElement('tr');
      row.style.cssText = index % 2 === 0 ? 'background: #f9f9f9;' : 'background: white;';
      
      // Image thumbnail
      const imgCell = document.createElement('td');
      imgCell.style.cssText = 'border: 1px solid #ddd; padding: 8px; text-align: center;';
      const thumbnail = document.createElement('img');
      thumbnail.src = img.src;
      thumbnail.style.cssText = 'max-width: 60px; max-height: 60px; object-fit: contain;';
      thumbnail.onerror = () => {
        thumbnail.style.display = 'none';
        imgCell.textContent = '[Image failed to load]';
      };
      imgCell.appendChild(thumbnail);
      
      // Alt attribute
      const altCell = document.createElement('td');
      altCell.style.cssText = 'border: 1px solid #ddd; padding: 8px; max-width: 200px; word-wrap: break-word;';
      altCell.textContent = img.getAttribute('alt') || '';
      
      // aria-label
      const ariaLabelCell = document.createElement('td');
      ariaLabelCell.style.cssText = 'border: 1px solid #ddd; padding: 8px; max-width: 200px; word-wrap: break-word;';
      ariaLabelCell.textContent = img.getAttribute('aria-label') || '';
      
      // aria-labelledby
      const ariaLabelledbyCell = document.createElement('td');
      ariaLabelledbyCell.style.cssText = 'border: 1px solid #ddd; padding: 8px; max-width: 200px; word-wrap: break-word;';
      ariaLabelledbyCell.textContent = resolveAriaLabelledby(img);
      
      // figcaption
      const figcaptionCell = document.createElement('td');
      figcaptionCell.style.cssText = 'border: 1px solid #ddd; padding: 8px; max-width: 200px; word-wrap: break-word;';
      figcaptionCell.textContent = getFigcaption(img);
      
      // Role
      const roleCell = document.createElement('td');
      roleCell.style.cssText = 'border: 1px solid #ddd; padding: 8px;';
      roleCell.textContent = img.getAttribute('role') || '';
      
      // Location
      const locationCell = document.createElement('td');
      locationCell.style.cssText = 'border: 1px solid #ddd; padding: 8px; max-width: 300px;';
      const locationDiv = document.createElement('div');
      
      const htmlSnippet = document.createElement('div');
      htmlSnippet.innerHTML = '<strong>HTML:</strong><br><code style="background: #f5f5f5; padding: 2px 4px; border-radius: 3px; font-size: 12px; display: block; margin: 4px 0; word-wrap: break-word; max-height: 80px; overflow-y: auto; white-space: pre-wrap;">' + 
        getHTMLSnippet(img).replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</code>';
      
      const xpathDiv = document.createElement('div');
      xpathDiv.innerHTML = '<strong>XPath:</strong><br><code style="background: #f5f5f5; padding: 2px 4px; border-radius: 3px; font-size: 12px; display: block; margin: 4px 0; word-wrap: break-word; max-height: 60px; overflow-y: auto; white-space: pre-wrap;">' + 
        getXPath(img) + '</code>';
      
      locationDiv.appendChild(htmlSnippet);
      locationDiv.appendChild(xpathDiv);
      locationCell.appendChild(locationDiv);
      
      row.appendChild(imgCell);
      row.appendChild(altCell);
      row.appendChild(ariaLabelCell);
      row.appendChild(ariaLabelledbyCell);
      row.appendChild(figcaptionCell);
      row.appendChild(roleCell);
      row.appendChild(locationCell);
      
      table.appendChild(row);
    });
    
    tableContainer.appendChild(table);
  }
  
  // Add summary
  const summary = document.createElement('div');
  summary.style.cssText = `
    padding: 15px 20px;
    border-top: 1px solid #ddd;
    background: #f8f9fa;
    border-radius: 0 0 8px 8px;
    font-size: 14px;
    color: #666;
  `;
  summary.textContent = `Total images found: ${images.length}`;
  
  // Assemble modal
  container.appendChild(header);
  container.appendChild(tableContainer);
  container.appendChild(summary);
  overlay.appendChild(container);
  
  // Add to page
  document.body.appendChild(overlay);
  
  // Close on overlay click
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) {
      document.body.removeChild(overlay);
    }
  });
})();
